{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/secrets/**)",
      "Read(./var/**)",
      "Read(./vendor/**)",
      "Read(./node_modules/**)",
      "Bash(git push --force*)",
      "Bash(bin/console doctrine:migrations:migrate*)",
      "Bash(symfony console doctrine:migrations:migrate*)",
      "Bash(composer require *)",
      "Bash(composer remove *)"
    ]
  }
}
