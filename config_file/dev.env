# Development environment sample.
# Copy the needed values into the app-specific .env.local files or your shell.

APP_ENV=dev
APP_DEBUG=1

DATABASE_URL=postgresql://app:app@127.0.0.1:5433/clickcollect?serverVersion=16&charset=utf8
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

OPENAI_API_KEY=
OPENAI_PRODUCT_ENRICHMENT_MODEL=gpt-4o-mini
OPENAI_PRODUCT_MAX_ACTIVE_BATCHES=1

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCKS=0
