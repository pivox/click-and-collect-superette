# Copy this file to .env.local and fill in the values
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development

# Set to "0" to call the real backend through src/lib/api.ts.
# Set to "1" (default) to use the in-memory mocks in src/lib/mock/.
# See src/lib/services/index.ts.
NEXT_PUBLIC_USE_MOCKS=1
